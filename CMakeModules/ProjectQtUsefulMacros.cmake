##################################
# Qt Component utility function
##################################

function(qtx_check_component_available qt_component qt_version)
	set(COMPONENT_AVAILABLE True)
	if (${qt_component} STREQUAL "QmlMeta" AND ${qt_version} VERSION_LESS "6.8")
		set(COMPONENT_AVAILABLE False)
	endif()
	if (${qt_component}  STREQUAL "QuickControls2Basic" AND ${qt_version} VERSION_LESS "6.7")
		set(COMPONENT_AVAILABLE False)
	endif()
	if (${qt_component}  STREQUAL "QuickControls2BasicStyleImpl" AND ${qt_version} VERSION_LESS "6.7")
		set(COMPONENT_AVAILABLE False)
	endif()
	if (${qt_component}  STREQUAL "QuickControls2Material" AND ${qt_version} VERSION_LESS "6.7")
		set(COMPONENT_AVAILABLE False)
	endif()
	if (${qt_component}  STREQUAL "QuickControls2MaterialStyleImpl" AND ${qt_version} VERSION_LESS "6.7")
		set(COMPONENT_AVAILABLE False)
	endif()
	if (${qt_component}  STREQUAL "QuickEffectsPrivate" AND ${qt_version} VERSION_LESS "6.5")
		set(COMPONENT_AVAILABLE False)
	endif()
	set(QTX_COMPONENT_${qt_component}_AVAILABLE ${COMPONENT_AVAILABLE} PARENT_SCOPE)
endfunction()

function(qtx_get_lib_name qt_component qt_libname)
	set(LIB_NAME ${qt_component})
	if (${qt_component} STREQUAL "QuickEffectsPrivate")
		set(LIB_NAME "QuickEffects")
	elseif (${qt_component} STREQUAL "QuickShapesPrivate")
		set(LIB_NAME "QuickShapes")
	elseif (${qt_component} STREQUAL "QuickDialogs2")
		set(LIB_NAME "QuickDialogs2")
	endif()
	set(${qt_libname} ${LIB_NAME} PARENT_SCOPE)
endfunction()

# Function to filter component depending on Qt version used
function(qtx_filter_components qt_initial_components qt_version QT_COMPONENTS)
	set(TMP_QT_COMPONENTS "")
	foreach(module ${qt_initial_components})
		qtx_check_component_available(${module} ${qt_version})
		if(QTX_COMPONENT_${module}_AVAILABLE)
			list(APPEND TMP_QT_COMPONENTS "${module}")
		else()
			message(STATUS "Qt component ${module} excluded for Qt version: ${qt_version}")
		endif()
	endforeach()
	set(${QT_COMPONENTS} "${TMP_QT_COMPONENTS}" PARENT_SCOPE)
endfunction()

