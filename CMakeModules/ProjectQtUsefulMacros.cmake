# Install qt component

function(install_qt_dll qt_dll_dir qt_component qt_version_major install_path)
	if(QT_USE_VERSION LESS 5)
		INSTALL(FILES "${qt_dll_dir}/${qt_component}${qt_version_major}.dll"
				DESTINATION ${install_path} CONFIGURATIONS Release)
		INSTALL(FILES "${qt_dll_dir}/${qt_component}d${qt_version_major}.dll"
				DESTINATION ${install_path} CONFIGURATIONS Debug)
	elseif(QT_USE_DEBUG_DLL)
		INSTALL(FILES "${qt_dll_dir}/Qt${qt_version_major}${qt_component}.dll"
				DESTINATION ${install_path} CONFIGURATIONS Release)
		INSTALL(FILES "${qt_dll_dir}/Qt${qt_version_major}${qt_component}d.dll"
				DESTINATION ${install_path} CONFIGURATIONS Debug)
	else()
		INSTALL(FILES "${qt_dll_dir}/Qt${qt_version_major}${qt_component}.dll"
				DESTINATION ${install_path})
	endif()
endfunction()

# Install qt plugin

function(install_qt_plugins_directory category)
	set(SRC_DIR ${QT_PLUGINS_DIR}/${category})
	set(DST_DIR ${INSTALL_PATH_QTPLUGINS})
	install(DIRECTORY "${SRC_DIR}" DESTINATION ${DST_DIR})
endfunction(install_qt_plugins_directory)

function(install_qt_plugins_dll qt_dll_dir qt_component qt_version_major install_path)
	if(QT_USE_DEBUG_DLL)
		INSTALL(FILES "${qt_dll_dir}/${qt_component}.dll"
				DESTINATION ${install_path} CONFIGURATIONS Release)
		INSTALL(FILES "${qt_dll_dir}/${qt_component}d.dll"
				DESTINATION ${install_path} CONFIGURATIONS Debug)
	else()
		INSTALL(FILES "${qt_dll_dir}/${qt_component}.dll"
				DESTINATION ${install_path})
	endif()
endfunction()

function(install_qt_plugins category components)
	set(SRC_DIR ${QT_PLUGINS_DIR}/${category})
	set(DST_DIR ${INSTALL_PATH_QTPLUGINS}/${category})
	foreach(TMP_COMPONENT ${components})
		message(STATUS "QT plugins installing: ${category} => ${components}")
		if (WIN32)
			install_qt_plugins_dll(${SRC_DIR} ${TMP_COMPONENT} ${QT_VERSION_MAJOR} ${DST_DIR})
		elseif(APPLE)
			install(FILES "${SRC_DIR}/lib${TMP_COMPONENT}.dylib" DESTINATION ${DST_DIR})
			if(EXISTS "${SRC_DIR}/lib${TMP_COMPONENT}_debug.dylib")
				install(FILES "${SRC_DIR}/lib${TMP_COMPONENT}_debug.dylib" DESTINATION ${DST_DIR} CONFIGURATIONS Debug)
			endif()
		else()
			if(AUTONOMOUS_PACKAGE_BUILD)
				install(FILES "${SRC_DIR}/lib${TMP_COMPONENT}.so" DESTINATION ${DST_DIR})
			endif()
		endif()
	endforeach(TMP_COMPONENT)
endfunction(install_qt_plugins)

# Install qt qm files

macro(install_qm_files qm_files_path qm_modules langs install_path)
	foreach(qm_module ${qm_modules})
		foreach(lang ${langs})
			file(GLOB FILES_INSTALL ${qm_files_path}/${qm_module}_${lang}*.qm)
			install(FILES ${FILES_INSTALL} DESTINATION ${install_path})
		endforeach()
	endforeach()
endmacro(install_qm_files)

# Install qt qml files

function(install_qml_directory qml_directory install_path)
	message(STATUS "Installing QML directory ${qml_directory}")
	install(DIRECTORY ${qml_directory} DESTINATION ${install_path} PATTERN "*.dll" EXCLUDE PATTERN "*.pdb" EXCLUDE PATTERN "*.so" EXCLUDE PATTERN "*.dylib" EXCLUDE)
endfunction(install_qml_directory)

function(install_qml_plugin qml_plugin_path qml_plugin_name install_path)
	message(STATUS "Installing QML plugin ${qml_plugin_name} from ${qml_plugin_path}")
	if(WIN32)
		set(TMP_BASE_PLUGIN_PATH "${qml_plugin_path}/${qml_plugin_name}")
	else()
		set(TMP_BASE_PLUGIN_PATH "${qml_plugin_path}/lib${qml_plugin_name}")
	endif()
	if(WIN32)
		if(QT_USE_DEBUG_DLL)
			install(FILES "${TMP_BASE_PLUGIN_PATH}.dll" DESTINATION ${TMP_TARGET_DIR} CONFIGURATIONS Release)
			install(FILES "${TMP_BASE_PLUGIN_PATH}d.dll" DESTINATION ${TMP_TARGET_DIR} CONFIGURATIONS Debug)
		else()
			install(FILES "${TMP_BASE_PLUGIN_PATH}.dll" DESTINATION ${TMP_TARGET_DIR})
		endif()
	elseif (APPLE)
		install(FILES "${TMP_BASE_PLUGIN_PATH}.dylib" DESTINATION ${TMP_TARGET_DIR})
	elseif(UNIX)
		install(FILES "${TMP_BASE_PLUGIN_PATH}.so" DESTINATION ${TMP_TARGET_DIR})
	endif()
endfunction(install_qml_plugin)